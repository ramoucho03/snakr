# Snak'r reverse proxy.
#
# {$APP_DOMAIN:localhost} resolves the site address from the APP_DOMAIN env var
# (passed by docker-compose), defaulting to `localhost`:
#   - localhost      -> Caddy serves HTTPS with its own internal CA (no ACME),
#                       so it "just works" for local testing on https://localhost.
#   - a real FQDN    -> Caddy provisions a public Let's Encrypt cert automatically
#                       (ports 80 + 443 must be reachable from the internet,
#                       and the `tls internal` line below must be removed).
#   - http://domain  -> plain HTTP, NO auto-redirect to HTTPS. REQUIRED when an
#                       external proxy (Nginx Proxy Manager…) terminates TLS and
#                       forwards here in HTTP: a bare FQDN would 308-redirect to
#                       https:// in a loop (ERR_TOO_MANY_REDIRECTS). Remove the
#                       `tls internal` line too (invalid on an http:// site).
#                       Simpler alternative: skip Caddy entirely with
#                       docker-compose.lan.yml and point the proxy at :3000.
#
# No request-body size cap is set: large uploads flow through the tus protocol in
# 8 MB chunks, and Caddy has no default upload limit to begin with.

{
	# Clients that connect by a bare IP (e.g. https://192.168.0.200) send NO SNI —
	# the TLS SNI extension only carries hostnames (RFC 6066). Without this, Caddy
	# has no name to select a certificate by and aborts the handshake ("internal
	# error" alert → ERR_SSL_PROTOCOL_ERROR). default_sni tells Caddy which site to
	# assume when the client sends none.
	default_sni {$APP_DOMAIN:localhost}
}

{$APP_DOMAIN:localhost} {
	# LAN / bare-IP deployments (e.g. APP_DOMAIN=192.168.0.200) can't get a public
	# Let's Encrypt cert, so force Caddy's INTERNAL CA — it always has a cert to
	# serve on 443. Browsers show a one-time "not trusted" warning (click through,
	# or install Caddy's root CA on clients). REMOVE this line when APP_DOMAIN is a
	# public FQDN, so Caddy uses a trusted Let's Encrypt certificate instead.
	tls internal

	# Transparent compression for text/JSON responses (never for already-compressed
	# media, which Caddy skips by content type).
	encode zstd gzip

	# Forward everything to the Next.js app. reverse_proxy sets X-Forwarded-For /
	# -Proto / -Host automatically so the app sees the real client + scheme.
	reverse_proxy app:3000
}
