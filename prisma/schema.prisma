// Snak'r — data model
// -----------------------------------------------------------------------------
// Physical bytes (Blob) are content-addressed by sha256 and reference-counted,
// fully decoupled from the logical tree (Folder / File). Sessions are DB-backed
// for instant revocation. Public share links store only a HASH of their token.
// Internal sharing is a resource/principal ACL (Permission).
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
  // native -> local dev (Windows/macOS/Linux)
  // musl   -> alpine runtime engine inside the Docker image
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ResourceType {
  FILE
  FOLDER
}

enum PrincipalType {
  USER
  GROUP
}

enum AccessLevel {
  READ
  WRITE
  OWNER
}

// Video sharing reach. PRIVATE = ACL only (default, unchanged behaviour).
// UNLISTED = anyone with the link, not surfaced publicly. PUBLIC = surfaced on
// the owner's channel and browsable without an account.
enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum ReactionKind {
  LIKE
  DISLIKE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  role         Role     @default(USER)
  storageLimit BigInt? // null = unlimited (default). Optional admin cap, in bytes.
  storageUsed  BigInt   @default(0) // bytes; reconciled on upload finish / delete
  mustChangePw Boolean  @default(false)
  isSuspended  Boolean  @default(false)
  avatarKey    String? // storage key of avatar derivative, optional
  // ── Channel / profile (member customization) ──────────────────────────────
  handle       String?  @unique // "@handle" for the public channel URL, optional
  bio          String? // short channel description shown on the profile
  bannerKey    String? // storage key of the channel banner image, optional
  accentColor  String? // personal accent (hex) applied to their channel header
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  folders       Folder[]
  files         File[]
  shares        Share[]
  memberships   GroupMember[]
  grantsGiven   Permission[]    @relation("GrantedBy")
  comments      Comment[]
  commentLikes  CommentLike[]
  reactions     VideoReaction[]
  subscriptions Subscription[]  @relation("Subscriber") // channels this user follows
  subscribers   Subscription[]  @relation("Channel") // users following this channel

  @@index([role])
}

model Session {
  id        String   @id @default(cuid()) // opaque; only this id (jose-encrypted) rides in the cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Folder?  @relation("Tree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("Tree")
  // Materialized ancestor path for O(1) inheritance resolution: "/rootId/childId/".
  path      String   @default("/")
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files  File[]
  shares Share[]

  @@index([ownerId])
  @@index([parentId])
  @@index([path])
}

// Physical bytes — content-addressed, deduplicated, reference-counted.
model Blob {
  hash      String   @id // sha256 hex = storage key + integrity check
  size      BigInt
  mimeType  String // sniffed from magic bytes, never client-supplied
  refCount  Int      @default(0)
  // ── Media probe (ffprobe), best-effort. It lives on the Blob because it is a
  // property of the BYTES: identical content dedups to one row and one probe.
  // A duration in the DB is what lets the grid drop its per-card metadata fetch
  // and what the player needs to size its buffer before the first byte plays.
  durationSec Float? // fractional seconds; null = unknown
  width       Int?
  height      Int?
  probedAt    DateTime? // stamped even when the probe finds nothing, so we never re-probe in a loop
  createdAt DateTime @default(now())

  files       File[]
  derivatives Derivative[]
}

// Logical file (metadata) — decoupled from disk layout.
model File {
  id        String   @id @default(cuid())
  name      String // original filename (metadata only, never a disk path)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  blobHash  String
  blob      Blob     @relation(fields: [blobHash], references: [hash])
  starred   Boolean  @default(false)
  // ── Video publishing metadata (harmless/nullable on non-video files) ───────
  description String? // long description shown under the player (video pages)
  visibility  Visibility @default(PRIVATE) // gate for anonymous /watch access
  viewCount   Int        @default(0)
  publishedAt DateTime? // first time visibility left PRIVATE (channel ordering)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shares    Share[]
  comments  Comment[]
  reactions VideoReaction[]

  @@index([ownerId])
  @@index([folderId])
  @@index([blobHash])
  @@index([visibility])
  // Channel listings filter on (owner, visibility) and order by publishedAt.
  @@index([ownerId, visibility, publishedAt])
}

// Thumbnails / posters, keyed by source blob so they're regenerable + cache-friendly.
model Derivative {
  id       String @id @default(cuid())
  blobHash String
  blob     Blob   @relation(fields: [blobHash], references: [hash], onDelete: Cascade)
  // "thumb"   → 640px WebP, grid poster
  // "poster"  → 1280×720 WebP + JPEG twin, social cards (og:image) & player poster
  // "preview" → ~6s silent 480p MP4, hover scrub preview
  // "fast"    → the source remuxed with the moov atom up front (instant start)
  kind     String
  key      String // storage key of the derived asset
  width    Int?
  height   Int?
  size     Int? // bytes; lets a route serve it without a stat() round-trip
  mimeType String? // derivative's own type ("fast" is not always the source type)

  @@unique([blobHash, kind])
}

// PUBLIC share links — store only the HASH of the token.
model Share {
  id            String    @id @default(cuid())
  fileId        String?
  file          File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId      String?
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique // sha256(token); the token itself is shown once
  passwordHash  String? // argon2id, optional
  expiresAt     DateTime?
  maxDownloads  Int?
  downloadCount Int       @default(0)
  allowUpload   Boolean   @default(false) // drop-box style folder shares
  revokedAt     DateTime?
  note          String?
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([createdById])
}

// INTERNAL sharing — ACL. One row per (resource, principal).
model Permission {
  id            String        @id @default(cuid())
  resourceType  ResourceType
  resourceId    String
  principalType PrincipalType
  principalId   String
  level         AccessLevel
  grantedById   String
  grantedBy     User          @relation("GrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  @@unique([resourceType, resourceId, principalType, principalId])
  @@index([principalType, principalId])
  @@index([resourceType, resourceId])
}

model Group {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  members   GroupMember[]
}

model GroupMember {
  groupId String
  userId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

// Global key/value settings (registration toggle, default quota, branding, ...).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Threaded comments on a video (File). Self-referential for replies; a delete
// cascades to its replies and its likes.
model Comment {
  id             String   @id @default(cuid())
  fileId         String
  file           File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId       String? // null = top-level comment
  parent         Comment? @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[] @relation("Thread")
  body           String
  pinned         Boolean  @default(false) // owner can pin one comment to the top
  heartedByOwner Boolean  @default(false) // creator "heart", YouTube-style
  edited         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  likes CommentLike[]

  @@index([fileId])
  @@index([parentId])
  @@index([authorId])
}

// A user's like on a comment. One row per (comment, user).
model CommentLike {
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([commentId, userId])
  @@index([userId])
}

// A user's like/dislike on a video. One row per (file, user); flipping the kind
// updates in place.
model VideoReaction {
  fileId    String
  file      File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      ReactionKind
  createdAt DateTime     @default(now())

  @@id([fileId, userId])
  @@index([fileId])
  @@index([userId])
}

// A subscription edge: `subscriber` follows `channel` (both are Users).
model Subscription {
  subscriberId String
  subscriber   User     @relation("Subscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  channelId    String
  channel      User     @relation("Channel", fields: [channelId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([subscriberId, channelId])
  @@index([channelId])
}
