# Snak'r environment — copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is gitignored and read at runtime via `env_file` in docker-compose.yml.
# NEVER commit real secrets, and never bake them into the image (ARG/ENV layers
# are inspectable) — they belong only in the runtime `.env`.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=snakr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=snakr

# ── App DB connection ─────────────────────────────────────────────────────────
# Points at the `postgres` compose service host. Keep user/password/db in sync
# with POSTGRES_* above. (docker-compose overrides this with the same value; for
# running the app OUTSIDE compose, swap `postgres` for `localhost`.)
DATABASE_URL="postgresql://snakr:changeme@postgres:5432/snakr?schema=public"

# ── Session ───────────────────────────────────────────────────────────────────
# 32-byte secret that signs/encrypts the session cookie. Generate a fresh one:
#   openssl rand -base64 32
SESSION_SECRET="replace-with-openssl-rand-base64-32"

# ── Initial admin (seeded on first boot only; never overwritten afterwards) ────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_NAME="Admin"

# ── Storage ───────────────────────────────────────────────────────────────────
# Upload root inside the container (backed by the `uploads` named volume).
STORAGE_ROOT="/data/uploads"

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── Caddy ─────────────────────────────────────────────────────────────────────
# Site address for the reverse proxy. `localhost` for local testing; set a public
# FQDN (e.g. files.example.com) for automatic Let's Encrypt TLS.
APP_DOMAIN="localhost"

# ── Optional ──────────────────────────────────────────────────────────────────
# Default per-user storage quota in bytes, seeded into Settings on first boot.
# Leave unset for unlimited. Example below is 10 GiB.
# DEFAULT_QUOTA_BYTES=10737418240

# ── Tailscale (optional — trusted HTTPS without a domain, PWA-installable) ────
# Auth key from https://login.tailscale.com/admin/settings/keys, used by the
# docker-compose.tailscale.yml overlay. See "Installer l'application (PWA)"
# in the README.
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
